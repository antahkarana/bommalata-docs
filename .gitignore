# Database files (contains user data, should not be committed)
data/
demo-data/
*.db
*.db-shm
*.db-wal

# Workspace files (agent-specific, may contain sensitive info)
demo-workspace/

# Logs may contain API keys or sensitive data
# We keep test-specific logs but exclude the main server.log
demo-logs/server.log

# Temporary files
/tmp/
*.tmp

# API keys and secrets (never commit these!)
*.env
secrets.env
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Build artifacts (if any)
bommalata
*.exe
